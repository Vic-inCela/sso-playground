{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "DATABASE_URL",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "NEXT_PUBLIC_BETTER_AUTH_URL",
        "CONSUMER_A_CLIENT_SECRET",
        "CONSUMER_A_ORIGIN",
        "CONSUMER_B_CLIENT_SECRET",
        "CONSUMER_B_ORIGIN",
        "IDP_DISCOVERY_URL",
        "IDP_CLIENT_ID",
        "IDP_CLIENT_SECRET",
        "CONSUMER_C_CLIENT_SECRET",
        "CONSUMER_C_ORIGIN",
        "API_BASE_URL_LOGIN",
        "AUTH_LOGIN_CLIENT_ID",
        "AUTH_LOGIN_AUTH_KIND",
        "AUTH_REQUEST_SOURCE",
        "UPSTREAM_WAF_HEADER_VALUE",
        "NEXT_PUBLIC_TURNSTILE_SITE_KEY"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^typecheck"]
    }
  }
}
